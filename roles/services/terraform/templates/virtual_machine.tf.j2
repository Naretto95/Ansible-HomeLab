resource "proxmox_virtual_environment_vm" "{{ item.name }}" {
  node_name = "{{ proxmox_node }}"
  name  = "{{ item.name }}"
  vm_id = {{ item.id }}

  clone {
    vm_id = {{ item.template_id }}
  }

  cpu {
    cores = {{ item.cores }}
  }

  memory {
    dedicated = {{ item.memory }}
  }

  disk {
    interface    = "scsi0"
    datastore_id = "{{ item.storage }}"
    size         = "{{ item.disk_size }}"
  }

  network_device {
    bridge = "{{ item.net_bridge }}"
    model  = "virtio"
  }

  initialization {
    ip_config {
      ipv4 {
        address = "{{ item.net_ip_address }}/{{ item.net_subnet }}"
        gateway  = "{{ item.net_gateway }}"
      }
    }

    user_account {
      username = "{{ item.cloud_user }}"
      password = "{{ item.cloud_password }}"
    }
  }

  started = true
}