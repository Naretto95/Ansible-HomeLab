[Unit]
Description=Gunicorn daemon for {{ django_app_name }}
After=network.target

[Service]
User=root
WorkingDirectory={{ django_app_dir }}

EnvironmentFile={{ django_app_dir }}/.env

ExecStart={{ venv_dir }}/bin/gunicorn \
    --workers {{ gunicorn_workers }} \
    --bind 0.0.0.0:80 \
    {{ django_project_module }}.wsgi:application

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target